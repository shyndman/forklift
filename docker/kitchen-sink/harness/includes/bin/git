#!/usr/bin/env bash
set -euo pipefail

# Thin git shim. During a paused rebase it hands control to the Python mediator,
# which enforces the mediated rebase vocabulary and round-trips each transition
# through the orchestrator over the intra-container control socket. The common
# non-rebase path execs the real git binary directly for native startup speed.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../common.sh
source "$SCRIPT_DIR/../common.sh"
# shellcheck source=../rebase.sh
source "$SCRIPT_DIR/../rebase.sh"

if rebase_in_progress; then
  HARNESS_PY=$(cd -- "$SCRIPT_DIR/../.." && pwd)/py
  exec env PYTHONPATH="$HARNESS_PY" python3 -m forklift_harness.mediate "$@"
fi

exec "$REAL_GIT_BIN" "$@"

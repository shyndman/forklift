#!/usr/bin/env bash
set -euo pipefail

# Thin git shim. During a paused rebase it hands control to the Python backstop,
# which enforces the target-repo rule on grandchild git that bypassed the
# in-process mediation toolset (tests, builds, the fork's continue-check, git's
# own recursion): workspace read-only and non-workspace git exec real git;
# workspace rebase-state mutators are refused. The common non-rebase path execs
# the real git binary directly for native startup speed.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../common.sh
source "$SCRIPT_DIR/../common.sh"
# shellcheck source=../rebase.sh
source "$SCRIPT_DIR/../rebase.sh"

if rebase_in_progress; then
  exec /opt/forklift/venv/bin/python -m forklift_harness.backstop "$@"
fi

exec "$REAL_GIT_BIN" "$@"
